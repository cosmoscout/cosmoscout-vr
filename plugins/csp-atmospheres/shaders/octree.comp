// --- Main Kernel ---
// [numthreads(64, 1, 1)]
void main() {
    // 1. Pop a task from the queue
    memoryBarrierAtomicCounter();
    memoryBarrier();
    barrier();
    uint currentQueueIdx = atomicCounter(head); // Returns val of head, then increments by 1
    memoryBarrierAtomicCounter();
    memoryBarrier();
    barrier();
    if (currentQueueIdx > MAX_NODES || currentQueueIdx > atomicCounter(tail))
        return; // No more work

    memoryBarrierAtomicCounter();
    memoryBarrier();
    barrier();
    uint nextQueueIdx = atomicCounterIncrement(head);
    memoryBarrierAtomicCounter();
    memoryBarrier();
    barrier();
    int currentNodeIdx = queue[nextQueueIdx];
    Node node = nodes[currentNodeIdx];

    // 2. Base Case: Max depth or already branch node
    if (node.depth >= MAX_DEPTH) {
        node.children[0] = -1; // Sets leaf node
        nodes[currentNodeIdx] = node;
        return;
    }

    // 3. Evaluate scalar field
    // float density = sampleDensity(node.boundsMin, node.boundsMax);
    float density = 1;
    if (density > VAR_THRESHOLD) {
        // --- SPLIT ---
        // Branch node
        
        // Allocate 8 children
        for (uint i = 0; i < 8; i++) {
            // For every child node, increment the running count of created nodes.
            memoryBarrierAtomicCounter();
            memoryBarrier();
            barrier();
            uint childIdx = atomicCounterIncrement(head);
            memoryBarrierAtomicCounter();
            memoryBarrier();
            barrier();

            Node child = nodes[childIdx];

            // Initialize child
            child.children[0] = -1; // -1 indicates valid leaf start
            child.depth = node.depth + 1;
            
            // Calculate child bounds
            vec3 centre = (node.boundsMin + node.boundsMax) * 0.5;
            vec3 cMin = node.boundsMin;
            vec3 cMax = node.boundsMax;

            // if (i & 1 > 0) cMin.x = centre.x; else cMax.x = centre.x; // Uneven => right-of-centre
            // if (i & 2 > 0) cMin.y = centre.y; else cMax.y = centre.y; // Behind centre
            // if (i & 4 > 0) cMin.z = centre.z; else cMax.z = centre.z; // Last four indices => above-centre

            nodes[childIdx].boundsMin = cMin;
            nodes[childIdx].boundsMax = cMax;
            
            // Link parent -> child
            node.children[i] = int(childIdx);

            // Push child to queue
            memoryBarrierAtomicCounter();
            memoryBarrier();
            barrier();
            uint tailIdx = atomicCounterIncrement(tail);
            memoryBarrierAtomicCounter();
            memoryBarrier();
            barrier();
            if (tailIdx < MAX_QUEUE) {
                queue[tailIdx] = int(childIdx);
            }
        }
    } else {
        // --- LEAF ---
        node.children[0] = -1; // Ensure it is marked as leaf
    }

    nodes[currentNodeIdx] = node;
    memoryBarrier();
    barrier();
}